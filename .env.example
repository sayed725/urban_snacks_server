# Environment Variables - Urban Snacks Server
# Copy this file to .env and fill in the values

NODE_ENV=development
PORT=5000

# Frontend Origins
APP_ORIGIN=http://localhost:3000
PROD_APP_ORIGIN=https://your-production-frontend.vercel.app

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/urban_snacks_db

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-min-10-chars
BETTER_AUTH_URL=http://localhost:5000

# Admin Seed Credentials
APP_ADMIN=Admin User
APP_ADMIN_EMAIL=admin@urbansnacks.com
APP_ADMIN_PASS=admin@12345
