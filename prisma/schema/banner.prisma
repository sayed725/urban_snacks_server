model Banner {
  id          String   @id @default(uuid())
  title       String?
  subtitle    String?
  badge       String?
  image       String?
  order       Int?
  banner      Boolean  @default(true)
  isActive    Boolean  @default(true)
  categoryId  String?
  buttonText  String?
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}
